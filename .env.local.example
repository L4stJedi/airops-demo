# Google Drive Integration
# 1. Create a service account in Google Cloud Console
# 2. Enable Google Drive API
# 3. Download JSON credentials
# 4. Share your Drive folders with the service account email
# 5. Paste the entire JSON as a single line below

GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com","client_id":"..."}

# Google Drive Folder IDs (from the URL: drive.google.com/drive/folders/THIS_PART)
DRIVE_FOLDER_SILESIA_AIR=your_silesia_air_folder_id_here
DRIVE_FOLDER_STREAM_AIR=your_stream_air_folder_id_here
