# ── Google OAuth (Workspace) ─────────────────────────────────────────────────
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Authorized redirect URI: https://your-domain.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback

# Maps email domains to companies (JSON)
# Default built-in: silesiaair.cz → silesia_air, airstreamjets.aero → stream_air
GOOGLE_DOMAIN_MAP={"silesiaair.cz":"silesia_air","airstreamjets.aero":"stream_air"}

# Session signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Google Drive ─────────────────────────────────────────────────────────────
# Paste the entire service account JSON as one line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Folder IDs from Drive URL: drive.google.com/drive/folders/FOLDER_ID
DRIVE_FOLDER_SILESIA_AIR=
DRIVE_FOLDER_STREAM_AIR=

# ── FL3XX Integration ─────────────────────────────────────────────────────────
# FL3XX API credentials (Client Credentials OAuth)
FL3XX_CLIENT_ID=
FL3XX_CLIENT_SECRET=
FL3XX_BASE_URL=https://api.fl3xx.com/api/v1

# Company IDs from FL3XX admin panel
FL3XX_COMPANY_ID_SILESIA=
FL3XX_COMPANY_ID_STREAM=

# ── App ───────────────────────────────────────────────────────────────────────
# Set to your deployment URL (needed for OAuth callbacks)
NEXTAUTH_URL=https://your-domain.vercel.app
